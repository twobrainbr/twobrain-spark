# ===== Spark (Chatwoot) - exemplo de .env de produção =====
# Copie para /opt/chatwoot/.env no servidor e preencha os segredos.
# Gere segredos com: openssl rand -hex 64

INSTALLATION_ENV=docker
RAILS_ENV=production
NODE_ENV=production

# Gere com: openssl rand -hex 64
SECRET_KEY_BASE=

# URL pública (atrás do Cloudflare)
FRONTEND_URL=https://spark.twobrain.com.br
DEFAULT_LOCALE=pt_BR
FORCE_SSL=false
ENABLE_ACCOUNT_SIGNUP=false

# Banco de dados (gere a senha com: openssl rand -hex 24)
POSTGRES_HOST=postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=
POSTGRES_DATABASE=chatwoot_production

# Redis (rede interna do docker)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# Storage local
ACTIVE_STORAGE_SERVICE=local
RAILS_MAX_THREADS=5

# ===== Inteligencia artificial (OpenAI) =====
# Crie uma chave exclusiva para cada ambiente. Nunca versione o valor real.
OPENAI_API_KEY=

# ===== SMTP (envio de e-mails) =====
MAILER_SENDER_EMAIL=Spark <nao-responda@twobrain.com.br>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
